<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Kumbh+Sans:wght@300;400;700&display=swap" rel="stylesheet">
{{ 'chat.css' | asset_url | stylesheet_tag }}
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<div class="shop-ai-chat-container">
  <div class="shop-ai-chat-bubble">
    <div class="shop-ai-bubble-layer shop-ai-bubble-layer-0"></div>
    <div class="shop-ai-bubble-layer shop-ai-bubble-layer-1"></div>
    <div class="shop-ai-bubble-layer shop-ai-bubble-layer-2"></div>
    <svg
      width="28"
      height="28"
      viewBox="0 0 56 56"
      fill="none"
      role="img"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path fill="#b07a78" d="M28.0078 0C43.466 0.000170143 55.9969 12.5363 55.9971 28C55.997 43.4638 43.4661 55.9998 28.0078 56C23.5449 56 19.3269 54.9533 15.583 53.0947C10.3065 55.3438 4.6113 56.0976 0.685547 55.9912C-0.0381847 55.9714 -0.247266 55.0569 0.341797 54.6357C3.79883 52.165 5.9927 49.5692 7.26953 46.8047C2.76354 41.8348 0.0175945 35.238 0.0175781 28C0.017732 12.5363 12.5496 0.000153788 28.0078 0Z"></path>
      <ellipse cx="18" cy="28" rx="2.5" ry="2.5" fill="#F4F4F6"></ellipse>
      <ellipse cx="28" cy="28" rx="2.5" ry="2.5" fill="#F4F4F6"></ellipse>
      <ellipse cx="38" cy="28" rx="2.5" ry="2.5" fill="#F4F4F6"></ellipse>
    </svg>
  </div>

  <div class="shop-ai-chat-window">
    <div class="shop-ai-chat-header">
      <button class="shop-ai-chat-back" aria-label="Back to home">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="shop-ai-chat-close" aria-label="Close chat">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="shop-ai-home-header">
      {% if block.settings.logo != blank %}
        <img src="{{ block.settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" class="shop-ai-home-logo" width="160" height="auto">
      {% else %}
        <img src="//www.rinfit.com/cdn/shop/files/Rinfit_Main_Logo.svg?v=1770977281&width=156" alt="{{ shop.name }}" class="shop-ai-home-logo" width="160" height="auto">
      {% endif %}
    </div>

    <div class="shop-ai-chat-messages">
      <!-- Messages will be added here by JavaScript -->
    </div>

    <div class="shop-ai-chat-input">
      <input type="text" placeholder="{{ 'chat.inputPlaceholder' | t }}">
      <div class="shop-ai-input-icons">
        <button class="shop-ai-input-icon shop-ai-image-icon" aria-label="Send message" disabled>
          <svg
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.53711 0.848145C8.79683 0.58853 9.21587 0.588517 9.47559 0.848145L17.1641 8.53662C17.4237 8.79633 17.4237 9.21537 17.1641 9.4751C16.9043 9.73482 16.4736 9.73479 16.2139 9.4751L9.66699 2.92822V17.1665C9.66699 17.5319 9.36628 17.8332 9.00098 17.8335C8.63545 17.8335 8.33398 17.532 8.33398 17.1665V2.93115L1.77637 9.4624C1.51565 9.72307 1.09664 9.7231 0.836914 9.46338C0.577483 9.20381 0.576775 8.78464 0.835938 8.5249L8.53711 0.848145Z" fill="currentColor"></path>
          </svg>
        </button>
        <button class="shop-ai-chat-send shop-ai-input-icon" aria-label="Send message" style="display: none;">
          <svg
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.53711 0.848145C8.79683 0.58853 9.21587 0.588517 9.47559 0.848145L17.1641 8.53662C17.4237 8.79633 17.4237 9.21537 17.1641 9.4751C16.9043 9.73482 16.4736 9.73479 16.2139 9.4751L9.66699 2.92822V17.1665C9.66699 17.5319 9.36628 17.8332 9.00098 17.8335C8.63545 17.8335 8.33398 17.532 8.33398 17.1665V2.93115L1.77637 9.4624C1.51565 9.72307 1.09664 9.7231 0.836914 9.46338C0.577483 9.20381 0.576775 8.78464 0.835938 8.5249L8.53711 0.848145Z" fill="currentColor"></path>
          </svg>
        </button>
      </div>
    </div>

    {% assign privacy_url = block.settings.privacy_policy_url | default: 'https://www.rinfit.com/pages/privacy-policy' %}
    <div class="shop-ai-chat-footer">
      AI-powered chat&nbsp;·&nbsp;Messages processed per our
      <a href="{{ privacy_url }}" target="_blank" rel="noopener noreferrer" class="shop-ai-privacy-link">Privacy Policy</a>
    </div>
  </div>
</div>

<script src="{{ 'chat.js' | asset_url }}" defer></script>
<script>
  window.shopChatConfig = {
    promptType: 'standardAssistant',
    welcomeMessage: {{ block.settings.welcome_message | json }},
    appUrl: 'https://shop-chat-agent-prod.fly.dev'
  };
  window.shopId = {{ shop.id }};
</script>

{% schema %}
{
  "name": "AI Chat Assistant",
  "target": "body",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Home Logo"
    },
    {
      "type": "text",
      "id": "welcome_message",
      "label": "Welcome Message",
      "default": "👋 Hi there! How can I help you today?"
    },
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "Privacy Policy URL"
    }
  ]
}
{% endschema %}
